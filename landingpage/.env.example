# Turso Database URL
VITE_TURSO_DATABASE_URL=libsql://your-database.turso.io
# Turso Auth Token
VITE_TURSO_AUTH_TOKEN=your-auth-token

# API base URL (dejar vacío si frontend y backend comparten dominio)
VITE_API_BASE_URL=

# Resiliencia — reintentos en llamadas GET fallidas
VITE_RETRY_RETRIES=3
VITE_RETRY_BACKOFF_MS=800
VITE_RETRY_TIMEOUT_MS=10000

# Cache local del sitio público — tiempo de vida en milisegundos (default: 24h)
VITE_CACHE_TTL_MS=86400000
